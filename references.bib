@article{PROMEL1999379,
title = {Non-Ramsey Graphs Are clogn-Universal},
journal = {Journal of Combinatorial Theory, Series A},
volume = {88},
number = {2},
pages = {379-384},
year = {1999},
issn = {0097-3165},
doi = {https://doi.org/10.1006/jcta.1999.2972},
url = {https://www.sciencedirect.com/science/article/pii/S0097316599929722},
author = {Hans Jürgen Prömel and Vojtěch Rödl},
abstract = {We prove that for any c1>0 there exists c2>0 such that the following state- ment is true: If G is a graph with n vertices and with the property that neither G nor its complement contains a complete graph Kl, where l=c1logn then G is c2logn-universal, i.e., G contains all subgraphs with c2logn vertices as induced subgraphs.}
}

